@model List<Warehouse.Web.Models.Item>

@{
    ViewData["Title"] = "Inventory Dashboard";
}

<div class="container mt-4">
    <h1 class="mb-4">📦 Warehouse Management System - Dashboard</h1>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Action Buttons -->
    <div class="row mb-4">
        <div class="col-md-12">
            <a href="@Url.Action("AddProduct")" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add/Update Product
            </a>
            <a href="@Url.Action("ProcessScan")" class="btn btn-info">
                <i class="bi bi-scanner"></i> Process Scan
            </a>
            <a href="@Url.Action("Reset")" class="btn btn-danger">
                <i class="bi bi-arrow-clockwise"></i> Reset Database
            </a>
        </div>
    </div>

    <!-- Inventory Table -->
    @if (Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>SKU</th>
                        <th>Product Name</th>
                        <th>Stock</th>
                        <th>Reorder Point</th>
                        <th>Safety Stock</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.Status.Contains("CRITICAL") ? "table-danger" : "")">
                            <td><strong>@item.ID</strong></td>
                            <td>@item.Name</td>
                            <td>@item.Stock</td>
                            <td>@item.ReorderPoint</td>
                            <td>@item.SafetyStock</td>
                            <td>${@item.CurrentPrice.ToString("F2")}</td>
                            <td>
                                @if (item.Status.Contains("CRITICAL"))
                                {
                                    <span class="badge bg-danger">@item.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.Status</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("DeleteProduct", new { id = item.ID })" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No products in inventory. <a href="@Url.Action("AddProduct")">Add one now!</a>
        </div>
    }
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }
</style>
